      ],
      "source": [
        "import sympy as sp\n",
        "\n",
        "q1,q2 = sp.symbols('q1 q2')\n",
        "\n",
        "a = 0.12\n",
        "b = 0.000002\n",
        "cost = 0.03\n",
        "\n",
        "P = a - b*(q1+q2)\n",
        "\n",
        "profit1 = (P-cost)*q1\n",
        "profit2 = (P-cost)*q2\n",
        "\n",
        "d1 = sp.diff(profit1,q1)\n",
        "d2 = sp.diff(profit2,q2)\n",
        "\n",
        "solution = sp.solve([d1,d2],[q1,q2])\n",
        "\n",
        "print(solution)"
      ]
    },
